model StorySaveSlot {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  workId       String    @map("work_id") @db.Uuid
  slotNumber   Int       @map("slot_number")
  releaseId    String    @map("release_id") @db.Uuid
  checkpointId String?   @map("checkpoint_id") @db.Uuid
  label        String?
  revision     Int       @default(1)
  status       String    @default("active")
  savedAt      DateTime  @default(now()) @map("saved_at") @db.Timestamptz(6)
  clearedAt    DateTime? @map("cleared_at") @db.Timestamptz(6)

  @@unique([userId, workId, slotNumber])
  @@index([userId, workId, savedAt], map: "idx_story_save_slots_user_work")
  @@map("story_save_slots")
}

model StoryEndingDiscovery {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  workId        String   @map("work_id") @db.Uuid
  releaseId     String   @map("release_id") @db.Uuid
  endingKey     String   @map("ending_key")
  endingKind    String   @map("ending_kind")
  pathSignature String   @map("path_signature")
  provenance    String
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)

  @@unique([userId, releaseId, endingKey, pathSignature])
  @@index([userId, workId, firstSeenAt], map: "idx_story_endings_user_work")
  @@map("story_ending_discoveries")
}

model StoryMemoryRecord {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId              String   @map("work_id") @db.Uuid
  analysisJobId       String   @map("analysis_job_id") @db.Uuid
  manuscriptVersionId String   @map("manuscript_version_id") @db.Uuid
  memoryType          String   @map("memory_type")
  memoryKey           String   @map("memory_key")
  partKey             String?  @map("part_key")
  content             Json
  evidenceIds         Json     @default("[]") @map("evidence_ids")
  provenance          String   @default("writer_original")
  status              String   @default("approved")
  revision            Int      @default(1)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([analysisJobId, memoryType, memoryKey])
  @@index([workId, memoryType, partKey], map: "idx_story_memory_work_type_part")
  @@map("story_memory_records")
}

model StoryMemoryRetrievalRun {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId            String    @map("work_id") @db.Uuid
  analysisJobId     String    @map("analysis_job_id") @db.Uuid
  idempotencyKey    String    @unique @map("idempotency_key")
  currentPartKey    String    @map("current_part_key")
  retrievalTypes    Json      @map("retrieval_types")
  selectedMemoryIds Json      @default("[]") @map("selected_memory_ids")
  checkpoint        String    @default("started")
  status            String    @default("running")
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([workId, analysisJobId, createdAt], map: "idx_story_memory_runs_work_analysis")
  @@map("story_memory_retrieval_runs")
}

model StoryWriterReview {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId              String    @map("work_id") @db.Uuid
  ownerUserId         String    @map("owner_user_id") @db.Uuid
  manuscriptVersionId String    @map("manuscript_version_id") @db.Uuid
  analysisJobId       String    @map("analysis_job_id") @db.Uuid
  state               String    @default("editing")
  revision            Int       @default(1)
  decisions           Json      @default("{}")
  finalSummary        Json      @default("{}") @map("final_summary")
  submittedAt         DateTime? @map("submitted_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([workId, manuscriptVersionId, analysisJobId])
  @@index([ownerUserId, updatedAt], map: "idx_story_writer_reviews_owner")
  @@map("story_writer_reviews")
}

model StoryFinalSubmission {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId            String   @unique @map("review_id") @db.Uuid
  manuscriptVersionId String   @map("manuscript_version_id") @db.Uuid
  idempotencyKey      String   @unique @map("idempotency_key")
  checksum            String
  status              String   @default("submitted")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("story_final_submissions")
}

model StoryQualityEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId         String   @map("work_id") @db.Uuid
  releaseId      String?  @map("release_id") @db.Uuid
  sessionKeyHash String   @map("session_key_hash")
  eventType      String   @map("event_type")
  metricBucket   String   @map("metric_bucket")
  dimensions     Json     @default("{}")
  numericValue   Decimal? @map("numeric_value") @db.Decimal(18, 6)
  idempotencyKey String   @unique @map("idempotency_key")
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([workId, releaseId, eventType, occurredAt], map: "idx_story_quality_events_work_release")
  @@map("story_quality_events")
}

model StoryQualityAggregate {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId        String   @map("work_id") @db.Uuid
  releaseId     String   @map("release_id") @db.Uuid
  metricKey     String   @map("metric_key")
  sampleCount   Int      @map("sample_count")
  numerator     Decimal? @db.Decimal(18, 6)
  denominator   Decimal? @db.Decimal(18, 6)
  measuredValue Decimal? @map("measured_value") @db.Decimal(18, 6)
  measuredAt    DateTime @default(now()) @map("measured_at") @db.Timestamptz(6)

  @@unique([workId, releaseId, metricKey])
  @@index([workId, measuredAt], map: "idx_story_quality_aggregates_work")
  @@map("story_quality_aggregates")
}

model StoryManuscriptVersion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId         String   @map("work_id") @db.Uuid
  ownerUserId    String   @map("owner_user_id") @db.Uuid
  version        Int
  locale         String
  contentHash    String   @map("content_hash")
  structuredBody Json     @map("structured_body")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([workId, version])
  @@unique([workId, contentHash])
  @@index([ownerUserId, createdAt], map: "idx_story_manuscripts_owner_created")
  @@map("story_manuscript_versions")
}

model StoryAnalysisJob {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manuscriptVersionId String    @map("manuscript_version_id") @db.Uuid
  analysisVersion     Int       @map("analysis_version")
  idempotencyKey      String    @unique @map("idempotency_key")
  status              String    @default("queued")
  result              Json      @default("{}")
  errorCode           String?   @map("error_code")
  startedAt           DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([manuscriptVersionId, analysisVersion])
  @@index([manuscriptVersionId, createdAt], map: "idx_story_analysis_manuscript")
  @@map("story_analysis_jobs")
}

model StoryAnalysisEvidence {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  analysisJobId        String   @map("analysis_job_id") @db.Uuid
  evidenceType         String   @map("evidence_type")
  sourcePartKey        String   @map("source_part_key")
  sourceParagraphIndex Int      @map("source_paragraph_index")
  payload              Json
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([analysisJobId, evidenceType], map: "idx_story_analysis_evidence_job_type")
  @@map("story_analysis_evidence")
}

model StoryContinuityEntry {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId        String   @map("work_id") @db.Uuid
  analysisJobId String   @map("analysis_job_id") @db.Uuid
  entryType     String   @map("entry_type")
  ledgerKey     String   @map("ledger_key")
  label         String
  evidenceIds   Json     @default("[]") @map("evidence_ids")
  state         String   @default("observed")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([analysisJobId, entryType, ledgerKey])
  @@index([workId, entryType, state], map: "idx_story_continuity_entries_work")
  @@map("story_continuity_entries")
}

model StoryContinuityIssue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId          String    @map("work_id") @db.Uuid
  analysisJobId   String    @map("analysis_job_id") @db.Uuid
  issueKey        String    @map("issue_key")
  severity        String
  status          String    @default("open")
  summary         String
  evidenceIds     Json      @default("[]") @map("evidence_ids")
  authorDecision  String?   @map("author_decision")
  decidedByUserId String?   @map("decided_by_user_id") @db.Uuid
  decidedAt       DateTime? @map("decided_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([analysisJobId, issueKey])
  @@index([workId, severity, status], map: "idx_story_continuity_issues_publish")
  @@map("story_continuity_issues")
}

model AuditEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorType   String   @map("actor_type")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id") @db.Uuid
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([targetType, targetId, createdAt], map: "idx_audit_events_target")
  @@map("audit_events")
}
