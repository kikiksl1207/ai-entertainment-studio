generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status               String                   @default("active")
  email                String?                  @unique
  phoneNumber          String?                  @unique @map("phone_number")
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?                @map("deleted_at") @db.Timestamptz(6)
  authAccounts         UserAuthAccount[]
  profile              UserProfile?
  settings             UserSettings?
  identityVerification UserIdentityVerification?
  payoutAccount        UserPayoutAccount?
  payoutException      UserPayoutException?
  refreshTokens        UserRefreshToken[]
  walletAccounts       WalletAccount[]
  videoUnlocks         UserPremiumVideoUnlock[]
  chatSessions         ChatSession[]
  chatFeatureOrders    ChatFeatureOrder[]
  fanLetters           FanLetter[]              @relation("FanLetterSender")
  entitlements         UserEntitlement[]
  paymentOrders        PaymentOrder[]
  auditEvents          AuditEvent[]
  adminAccess          AdminUser?               @relation("AdminAccess")
  createdAdminUsers    AdminUser[]              @relation("AdminCreatedBy")
  referralCode         UserReferralCode?
  sentReferrals        ReferralReward[]         @relation("ReferralReferrer")
  receivedReferral     ReferralReward?          @relation("ReferralReferred")
  attendanceRewards    DailyAttendanceReward[]
  sentUserGifts        UserGiftTransfer[]       @relation("UserGiftSender")
  receivedUserGifts    UserGiftTransfer[]       @relation("UserGiftRecipient")
  actionTokens         UserActionToken[]
  debutApplications    DebutApplication[]
  artistOperators      ArtistOperator[]
  communityPosts       CommunityPost[]          @relation("CommunityPostAuthor")
  communityReplies     CommunityReply[]         @relation("CommunityReplyAuthor")
  communityReactions   CommunityReaction[]
  feedSearchEvents     FeedSearchEvent[]
  feedSearchBlockedTerms FeedSearchBlockedTerm[]
  communityReports     CommunityReport[]        @relation("CommunityReportReporter")
  hiddenCommunityPosts CommunityHiddenPost[]
  artistFollows        ArtistFollow[]
  followingUsers       UserFollow[]             @relation("UserFollowFollower")
  followers            UserFollow[]             @relation("UserFollowFollowing")
  blockedUsers         UserBlock[]              @relation("UserBlockBlocker")
  blockedByUsers       UserBlock[]              @relation("UserBlockBlocked")
  notifications        UserNotification[]       @relation("UserNotificationRecipient")
  notificationActions  UserNotification[]       @relation("UserNotificationActor")
  creatorImageRequests CreatorImageRequest[]    @relation("CreatorImageRequestRequester")
  moderationReports    ModerationReport[]       @relation("ModerationReportReporter")

  @@index([status], map: "idx_users_status")
  @@map("users")
}

model UserActionToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  purpose    String
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, purpose, consumedAt, expiresAt], map: "idx_user_action_tokens_user_purpose")
  @@map("user_action_tokens")
}

model UserAuthAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String
  providerUserId String    @map("provider_user_id")
  passwordHash   String?   @map("password_hash")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@map("user_auth_accounts")
}

model UserProfile {
  userId            String    @id @map("user_id") @db.Uuid
  displayName       String    @map("display_name")
  publicHandle      String    @unique @map("public_handle")
  avatarAssetId     String?   @map("avatar_asset_id") @db.Uuid
  coverAssetId      String?   @map("cover_asset_id") @db.Uuid
  bio               String?
  nicknameChangedAt DateTime? @map("nickname_changed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model UserSettings {
  userId                String   @id @map("user_id") @db.Uuid
  locale                String   @default("ko-KR")
  timezone              String   @default("Asia/Seoul")
  marketingOptIn        Boolean  @default(false) @map("marketing_opt_in")
  pushOptIn             Boolean  @default(false) @map("push_opt_in")
  activityNotifications Boolean  @default(true) @map("activity_notifications")
  feedNotifications     Boolean  @default(true) @map("feed_notifications")
  emailNotifications    Boolean  @default(false) @map("email_notifications")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                  User     @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

model UserIdentityVerification {
  userId             String    @id @map("user_id") @db.Uuid
  status             String    @default("unverified")
  provider           String?
  verifiedNameMasked String?   @map("verified_name_masked")
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user               User      @relation(fields: [userId], references: [id])

  @@index([status], map: "idx_user_identity_verifications_status")
  @@map("user_identity_verifications")
}

model UserPayoutAccount {
  userId                String   @id @map("user_id") @db.Uuid
  status                String   @default("missing")
  bankName              String?  @map("bank_name")
  accountHolderMasked   String?  @map("account_holder_masked")
  accountLast4          String?  @map("account_last4")
  holderMatchesIdentity Boolean  @default(false) @map("holder_matches_identity")
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user                  User     @relation(fields: [userId], references: [id])

  @@index([status], map: "idx_user_payout_accounts_status")
  @@map("user_payout_accounts")
}

model UserPayoutException {
  userId           String    @id @map("user_id") @db.Uuid
  status           String    @default("none")
  reason           String?
  documentAttached Boolean   @default(false) @map("document_attached")
  approvedByUserId String?   @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz(6)
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id])

  @@index([status], map: "idx_user_payout_exceptions_status")
  @@map("user_payout_exceptions")
}

model UserRefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedBy String?   @map("replaced_by") @db.Uuid
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, expiresAt], map: "idx_refresh_tokens_user_active")
  @@map("user_refresh_tokens")
}

model AdminRole {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @unique
  description String?
  permissions String[]    @default([])
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  adminUsers  AdminUser[]

  @@map("admin_roles")
}

model AdminUser {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  roleId          String    @map("role_id") @db.Uuid
  status          String    @default("active")
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  lastAccessAt    DateTime? @map("last_access_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  user            User      @relation("AdminAccess", fields: [userId], references: [id])
  role            AdminRole @relation(fields: [roleId], references: [id])
  createdBy       User?     @relation("AdminCreatedBy", fields: [createdByUserId], references: [id])

  @@index([status], map: "idx_admin_users_status")
  @@index([roleId], map: "idx_admin_users_role")
  @@map("admin_users")
}

model Artist {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String                  @unique
  displayName       String                  @map("display_name")
  status            String                  @default("draft")
  sortOrder         Int                     @default(0) @map("sort_order")
  launchedAt        DateTime?               @map("launched_at") @db.Timestamptz(6)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  publicProfile     ArtistPublicProfile?
  visualProfile     ArtistVisualProfile?
  contentProfile    ArtistContentProfile?
  artistAssets      ArtistAsset[]
  shortforms        Shortform[]
  giftProducts      GiftProduct[]
  giftOrders        GiftOrder[]
  giftProgress      ArtistGiftProgress[]
  reactionEvents    ArtistReactionEvent[]
  equippedItems     ArtistEquippedItem[]
  boostEvents       ArtistBoostEvent[]
  rankingScores     ArtistRankingSnapshot[]
  monthlyPickWins   MonthlyPickWinner[]
  premiumVideos     PremiumVideoProduct[]
  chatPersonas      ChatPersona[]
  chatSessions      ChatSession[]
  chatFeatureOrders ChatFeatureOrder[]
  fanLetters        FanLetter[]
  artistOperators   ArtistOperator[]
  communityPosts    CommunityPost[]
  followers         ArtistFollow[]
  notifications     UserNotification[]
  creatorImageRequests CreatorImageRequest[]

  @@index([status, sortOrder], map: "idx_artists_status_sort")
  @@map("artists")
}

model ArtistOperator {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  artistId    String    @map("artist_id") @db.Uuid
  role        String    @default("owner")
  status      String    @default("active")
  permissions String[]  @default([])
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id])
  artist      Artist    @relation(fields: [artistId], references: [id])

  @@unique([userId, artistId])
  @@index([artistId, status], map: "idx_artist_operators_artist_status")
  @@index([userId, status], map: "idx_artist_operators_user_status")
  @@map("artist_operators")
}

model CreatorImageRequest {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterUserId   String   @map("requester_user_id") @db.Uuid
  artistId          String   @map("artist_id") @db.Uuid
  requestType       String   @map("request_type")
  title             String?
  brief             String
  prompt            String?
  referenceAssetIds Json     @default("[]") @map("reference_asset_ids")
  resultAssetIds    Json     @default("[]") @map("result_asset_ids")
  status            String   @default("submitted")
  moderationStatus  String   @default("pending") @map("moderation_status")
  adminNote         String?  @map("admin_note")
  rejectionReason   String?  @map("rejection_reason")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  requester         User     @relation("CreatorImageRequestRequester", fields: [requesterUserId], references: [id])
  artist            Artist   @relation(fields: [artistId], references: [id])

  @@index([requesterUserId, createdAt], map: "idx_creator_image_requests_requester_created")
  @@index([artistId, status, createdAt], map: "idx_creator_image_requests_artist_status")
  @@index([status, createdAt], map: "idx_creator_image_requests_status_created")
  @@map("creator_image_requests")
}

model ArtistPublicProfile {
  artistId            String   @id @map("artist_id") @db.Uuid
  tagline             String?
  summary             String?
  personalityKeywords String[] @default([]) @map("personality_keywords")
  publicStory         String?  @map("public_story")
  publicMetadata      Json     @default("{}") @map("public_metadata")
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  artist              Artist   @relation(fields: [artistId], references: [id])

  @@map("artist_public_profiles")
}

model ArtistVisualProfile {
  artistId       String   @id @map("artist_id") @db.Uuid
  visualKeywords String[] @default([]) @map("visual_keywords")
  styleNotes     String?  @map("style_notes")
  primaryColor   String?  @map("primary_color")
  secondaryColor String?  @map("secondary_color")
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  artist         Artist   @relation(fields: [artistId], references: [id])

  @@map("artist_visual_profiles")
}

model ArtistContentProfile {
  artistId       String   @id @map("artist_id") @db.Uuid
  contentTone    String?  @map("content_tone")
  allowedTopics  String[] @default([]) @map("allowed_topics")
  blockedTopics  String[] @default([]) @map("blocked_topics")
  operatingNotes String?  @map("operating_notes")
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  artist         Artist   @relation(fields: [artistId], references: [id])

  @@map("artist_content_profiles")
}

model Asset {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetType          String              @map("asset_type")
  visibility         String              @default("public")
  storageProvider    String              @default("local") @map("storage_provider")
  storageKey         String              @map("storage_key")
  mimeType           String              @map("mime_type")
  fileSizeBytes      BigInt?             @map("file_size_bytes")
  width              Int?
  height             Int?
  durationSeconds    Decimal?            @map("duration_seconds") @db.Decimal(12, 3)
  checksum           String?
  metadata           Json                @default("{}")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  artistAssets       ArtistAsset[]
  shortformAssets    ShortformAsset[]
  premiumVideoAssets PremiumVideoAsset[]
  communityPostAssets CommunityPostAsset[]

  @@unique([storageProvider, storageKey])
  @@index([assetType, visibility], map: "idx_assets_type_visibility")
  @@map("assets")
}

model ArtistAsset {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artistId  String   @map("artist_id") @db.Uuid
  assetId   String   @map("asset_id") @db.Uuid
  usageType String   @map("usage_type")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  artist    Artist   @relation(fields: [artistId], references: [id])
  asset     Asset    @relation(fields: [assetId], references: [id])

  @@unique([artistId, assetId, usageType])
  @@index([artistId, usageType], map: "idx_artist_assets_artist_usage")
  @@map("artist_assets")
}

model Shortform {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artistId    String?          @map("artist_id") @db.Uuid
  title       String
  slug        String           @unique
  description String?
  status      String           @default("draft")
  publishedAt DateTime?        @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  artist      Artist?          @relation(fields: [artistId], references: [id])
  assets      ShortformAsset[]

  @@index([artistId, status, publishedAt], map: "idx_shortforms_artist_status")
  @@map("shortforms")
}

model ShortformAsset {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortformId String    @map("shortform_id") @db.Uuid
  assetId     String    @map("asset_id") @db.Uuid
  role        String
  sortOrder   Int       @default(0) @map("sort_order")
  shortform   Shortform @relation(fields: [shortformId], references: [id])
  asset       Asset     @relation(fields: [assetId], references: [id])

  @@unique([shortformId, assetId, role])
  @@map("shortform_assets")
}

model WalletAccount {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  currencyCode  String         @default("LUMINA") @map("currency_code")
  status        String         @default("active")
  cachedBalance Decimal        @default(0) @map("cached_balance") @db.Decimal(18, 2)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  user          User           @relation(fields: [userId], references: [id])
  ledgerEntries WalletLedger[]

  @@unique([userId, currencyCode])
  @@map("wallet_accounts")
}

model WalletLedger {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletAccountId     String                   @map("wallet_account_id") @db.Uuid
  direction           String
  amount              Decimal                  @db.Decimal(18, 2)
  ledgerType          String                   @map("ledger_type")
  referenceType       String?                  @map("reference_type")
  referenceId         String?                  @map("reference_id") @db.Uuid
  idempotencyKey      String?                  @unique @map("idempotency_key")
  memo                String?
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  walletAccount       WalletAccount            @relation(fields: [walletAccountId], references: [id])
  giftOrders          GiftOrder[]
  artistBoostEvents   ArtistBoostEvent[]
  premiumVideoUnlocks UserPremiumVideoUnlock[]
  chatFeatureOrders   ChatFeatureOrder[]
  fanLetters          FanLetter[]

  @@index([walletAccountId, createdAt], map: "idx_wallet_ledger_account_created")
  @@index([referenceType, referenceId], map: "idx_wallet_ledger_reference")
  @@map("wallet_ledger")
}

model UserReferralCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  code      String   @unique
  status    String   @default("active")
  useCount  Int      @default(0) @map("use_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])

  @@index([status], map: "idx_user_referral_codes_status")
  @@map("user_referral_codes")
}

model ReferralReward {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerUserId   String   @map("referrer_user_id") @db.Uuid
  referredUserId   String   @unique @map("referred_user_id") @db.Uuid
  referralCodeId   String   @map("referral_code_id") @db.Uuid
  referrerAmount   Decimal  @map("referrer_amount") @db.Decimal(18, 2)
  referredAmount   Decimal  @map("referred_amount") @db.Decimal(18, 2)
  referrerLedgerId String?  @map("referrer_ledger_id") @db.Uuid
  referredLedgerId String?  @map("referred_ledger_id") @db.Uuid
  status           String   @default("granted")
  idempotencyKey   String   @unique @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  referrer         User     @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred         User     @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@index([referrerUserId, createdAt], map: "idx_referral_rewards_referrer_created")
  @@index([referralCodeId], map: "idx_referral_rewards_code")
  @@map("referral_rewards")
}

model DailyAttendanceReward {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  serviceDate    DateTime @map("service_date") @db.Date
  rewardLumina   Decimal  @map("reward_lumina") @db.Decimal(18, 2)
  walletLedgerId String?  @map("wallet_ledger_id") @db.Uuid
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, serviceDate])
  @@index([serviceDate], map: "idx_daily_attendance_rewards_date")
  @@map("daily_attendance_rewards")
}

model UserGiftTransfer {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senderUserId      String   @map("sender_user_id") @db.Uuid
  recipientUserId   String   @map("recipient_user_id") @db.Uuid
  amountLumina      Decimal  @map("amount_lumina") @db.Decimal(18, 2)
  senderLedgerId    String?  @map("sender_ledger_id") @db.Uuid
  recipientLedgerId String?  @map("recipient_ledger_id") @db.Uuid
  message           String?
  status            String   @default("completed")
  idempotencyKey    String?  @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  sender            User     @relation("UserGiftSender", fields: [senderUserId], references: [id])
  recipient         User     @relation("UserGiftRecipient", fields: [recipientUserId], references: [id])

  @@index([senderUserId, createdAt], map: "idx_user_gift_transfers_sender_created")
  @@index([recipientUserId, createdAt], map: "idx_user_gift_transfers_recipient_created")
  @@map("user_gift_transfers")
}

model LuminaProduct {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku           String         @unique
  name          String
  luminaAmount  Decimal        @map("lumina_amount") @db.Decimal(18, 2)
  bonusAmount   Decimal        @default(0) @map("bonus_amount") @db.Decimal(18, 2)
  priceAmount   Decimal        @map("price_amount") @db.Decimal(18, 2)
