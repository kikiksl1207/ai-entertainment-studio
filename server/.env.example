DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lumina_stage?schema=public"
PORT=3001
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
JWT_ACCESS_SECRET="replace-with-at-least-32-characters-access-secret"
JWT_REFRESH_SECRET="replace-with-at-least-32-characters-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PAYMENT_SUCCESS_URL="http://localhost:3000/payments/success"
PAYMENT_FAIL_URL="http://localhost:3000/payments/fail"
PAYMENT_PROVIDER="mock"
MOCK_PAYMENT_CLIENT_KEY="mock-client-key"
MOCK_PAYMENT_WEBHOOK_SECRET="replace-with-at-least-32-characters-webhook-secret"
