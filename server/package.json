{
  "name": "lumina-stage-server",
  "version": "0.1.0",
  "private": true,
  "description": "Lumina Stage NestJS backend API",
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:fast": "node -r ts-node/register/transpile-only prisma/seed.ts",
    "qa:debut-status-fixtures": "node scripts/create-debut-status-owner-fixtures.mjs",
    "qa:debut-status-owner-projection": "node scripts/verify-debut-status-owner-projection.mjs",
    "qa:auth-credential-source": "node scripts/verify-auth-qa-credential-source.mjs",
    "qa:auth-access-self-check": "node scripts/verify-auth-qa-access-self-check.mjs",
    "qa:chat-conversation-list": "node scripts/verify-chat-conversation-list-fixture.mjs",
    "qa:chat-archive-fixture": "node scripts/prepare-chat-archive-conversation-fixture.mjs",
    "qa:follower-block-fixture": "node scripts/prepare-follower-block-qa-fixture.mjs",
    "qa:premium-chat-live-fixtures": "node scripts/prepare-premium-chat-live-qa-fixtures.mjs",
    "qa:story-upload-intake-staging": "node scripts/verify-story-upload-intake-staging.mjs",
    "render:start": "npm run prisma:deploy && npm run start:prod",
    "render:start:seed": "npm run prisma:deploy && npm run prisma:seed:fast && npm run start:prod",
    "verify:object-storage": "node scripts/verify-object-storage-upload.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "pretest": "prisma generate",
    "test": "jest"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.3.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
